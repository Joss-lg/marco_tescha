---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Generador de Marco Fotográfico | TESCHA",
	description = "Generador de marcos fotográficos del Tecnológico de Estudios Superiores de Chalco.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<meta name="description" content={description} />

		<link rel="icon" href="/imagenes/Rqq.ico" />

		<title>{title}</title>
	</head>

	<body class="min-h-screen bg-slate-100 font-sans text-slate-800 antialiased">
		<slot />
	</body>
</html>