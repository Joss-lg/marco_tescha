---
// src/components/CanvasEditor.astro
---

<section
    id="canvas-editor"
    aria-labelledby="preview-title"
    class="rounded-xl border border-slate-200 bg-slate-50 p-5"
>
    <!-- Título de la sección actualizado al color guinda institucional -->
    <h2
        id="preview-title"
        class="text-center text-xl font-semibold text-tescha-wine"
    >
        Vista previa
    </h2>

    <!-- Selector de Interacción (Fotografía / Marco) -->
    <div class="mt-4 flex items-center justify-center gap-3 bg-white p-2 rounded-xl border border-slate-200 max-w-xs mx-auto">
        <span class="text-sm font-medium text-slate-700">Interacción:</span>
        <div class="flex bg-slate-100 p-1 rounded-lg gap-1 w-full">
            <button
                id="target-photo-btn"
                type="button"
                class="flex-1 text-xs font-semibold py-1.5 px-3 rounded-md transition-all bg-white text-slate-800 shadow-sm"
            >
                Fotografía
            </button>
            <button
                id="target-frame-btn"
                type="button"
                class="flex-1 text-xs font-semibold py-1.5 px-3 rounded-md transition-all text-slate-500 hover:text-slate-800"
            >
                Marco
            </button>
        </div>
    </div>

    <!-- Contenedor del Canvas (Lienzo rectangular vertical Oficio) -->
    <div
        class="mt-5 overflow-hidden rounded-lg bg-slate-200 shadow-inner flex items-center justify-center relative select-none p-2"
    >
        <canvas
            id="photo-canvas"
            width="2550"
            height="4000"
            class="w-full h-auto max-h-[70vh] object-contain border border-slate-300 rounded-lg shadow-inner bg-slate-50 cursor-grab active:cursor-grabbing"
            aria-label="Vista previa de la fotografía con el marco del TESCHA"
        ></canvas>
    </div>

    <p
        id="canvas-placeholder"
        class="mt-4 text-center text-sm text-slate-500"
    >
        Selecciona una fotografía para comenzar. Puedes arrastrar el elemento seleccionado dentro del lienzo.
    </p>

    <!-- Botón de descarga integrado -->
<!-- Botón de descarga integrado con el color guinda institucional -->
	<div class="mt-5">
		<button
			id="download-btn"
			type="button"
			class="w-full bg-tescha-wine hover:bg-[#611626] text-white font-semibold py-3 px-6 rounded-xl shadow-md transition-colors flex items-center justify-center gap-2 cursor-pointer"
		>
			<svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
			</svg>
			Descargar Imagen Final
		</button>
	</div>
</section>

<script>
    const canvas = document.querySelector<HTMLCanvasElement>("#photo-canvas");
    const placeholder = document.querySelector<HTMLElement>("#canvas-placeholder");
    const downloadBtn = document.querySelector<HTMLButtonElement>("#download-btn");
    
    // Botones del selector táctil/interacción
    const targetPhotoBtn = document.querySelector<HTMLButtonElement>("#target-photo-btn");
    const targetFrameBtn = document.querySelector<HTMLButtonElement>("#target-frame-btn");
    
    const context = canvas?.getContext("2d");

    let photo: HTMLImageElement | null = null;
    let photoUrl: string | null = null;
    
    // Estado de la fotografía del usuario (Capa de fondo)
    let photoScale = 1;
    let photoX = 0;
    let photoY = 0;

    // Estado del Marco Institucional (Capa del frente)
    let frameScale = 1;
    let frameX = 0;
    let frameY = 0;

    // Inicializar objeto de imagen para el Marco Oficial
    const frame = new Image();
    let frameLoaded = false;

    // Control de interacción ("photo" o "frame")
    let currentTarget: "photo" | "frame" = "photo";

    // Variables para el arrastre con el mouse
    let isDragging = false;
    let startX = 0;
    let startY = 0;

    function paintEmptyCanvas() {
        if (!canvas || !context) return;
        context.fillStyle = "#ffffff"; 
        context.fillRect(0, 0, canvas.width, canvas.height);
        
        if (frameLoaded) {
            context.drawImage(frame, 0, 0, canvas.width, canvas.height);
        }
    }

    function renderPhoto() {
        if (!canvas || !context) return;

        context.clearRect(0, 0, canvas.width, canvas.height);
        context.fillStyle = "#ffffff";
        context.fillRect(0, 0, canvas.width, canvas.height);

        // CAPA INFERIOR: Fotografía del usuario
        if (photo) {
            const baseScale = Math.max(
                canvas.width / photo.naturalWidth,
                canvas.height / photo.naturalHeight,
            );
            
            const width = photo.naturalWidth * baseScale * photoScale;
            const height = photo.naturalHeight * baseScale * photoScale;
            
            const x = (canvas.width - width) / 2 + (canvas.width * photoX) / 100;
            const y = (canvas.height - height) / 2 + (canvas.height * photoY) / 100;

            context.drawImage(photo, x, y, width, height);
        }

        // CAPA SUPERIOR: Marco Institucional
        if (frameLoaded) {
            const frameWidth = canvas.width * frameScale;
            const frameHeight = canvas.height * frameScale;
            
            const frameXPos = ((canvas.width - frameWidth) / 2) + (canvas.width * frameX) / 100;
            const frameYPos = ((canvas.height - frameHeight) / 2) + (canvas.height * frameY) / 100;

            context.save();
            context.drawImage(frame, frameXPos, frameYPos, frameWidth, frameHeight);
            context.restore();
        }
    }

    frame.addEventListener("load", () => {
        frameLoaded = true;
        renderPhoto();
    });

    // ¡CORREGIDO! Nombre de archivo institucional exacto: MarcoTESCHA.png
    frame.src = "/imagenes/Marco TESCHA.png"; 

    // --- INTERRUPTOR DE INTERACCIÓN (MANEJO DE UI DE BOTONES) ---
    function updateToggleUI() {
        if (currentTarget === "photo") {
            targetPhotoBtn?.classList.add("bg-white", "text-slate-800", "shadow-sm");
            targetPhotoBtn?.classList.remove("text-slate-500");
            targetFrameBtn?.classList.remove("bg-white", "text-slate-800", "shadow-sm");
            targetFrameBtn?.classList.add("text-slate-500");
        } else {
            targetFrameBtn?.classList.add("bg-white", "text-slate-800", "shadow-sm");
            targetFrameBtn?.classList.remove("text-slate-500");
            targetPhotoBtn?.classList.remove("bg-white", "text-slate-800", "shadow-sm");
            targetPhotoBtn?.classList.add("text-slate-500");
        }
    }

    targetPhotoBtn?.addEventListener("click", () => { currentTarget = "photo"; updateToggleUI(); });
    targetFrameBtn?.addEventListener("click", () => { currentTarget = "frame"; updateToggleUI(); });

    // --- MANEJO DE ARRASTRE DIRECTO EN CANVAS ---
    canvas?.addEventListener("mousedown", (e) => {
        if (currentTarget === "photo" && !photo) return; 

        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;
    });

    window.addEventListener("mousemove", (e) => {
        if (!isDragging || !canvas) return;

        const deltaX = e.clientX - startX;
        const deltaY = e.clientY - startY;

        startX = e.clientX;
        startY = e.clientY;

        const rect = canvas.getBoundingClientRect();
        const percentX = (deltaX / rect.width) * 100;
        const percentY = (deltaY / rect.height) * 100;

        if (currentTarget === "photo") {
            photoX += percentX;
            photoY += percentY;
        } else {
            frameX += percentX;
            frameY += percentY;
        }

        renderPhoto();

        // Sincronizar el estado con los controles deslizantes
        const updateEvent = new CustomEvent("canvas:sync", {
            detail: { photoX, photoY, frameX, frameY }
        });
        document.dispatchEvent(updateEvent);
    });

    window.addEventListener("mouseup", () => {
        isDragging = false;
    });

    // --- ESCUCHADORES DE EVENTOS GLOBALES ---
    document.addEventListener("photo:adjust", (event) => {
        const adjustments = (event as CustomEvent<{ scale: number; x: number; y: number }>).detail;
        photoScale = adjustments.scale;
        photoX = adjustments.x;
        photoY = adjustments.y;
        renderPhoto();
    });

    document.addEventListener("frame:adjust", (event) => {
        const adjustments = (event as CustomEvent<{ scale: number; x: number; y: number }>).detail;
        frameScale = adjustments.scale;
        frameX = adjustments.x;
        frameY = adjustments.y;
        renderPhoto();
    });

    document.addEventListener("photo:selected", (event) => {
        const selectedFile = (event as CustomEvent<File>).detail;
        if (photoUrl) {
            URL.revokeObjectURL(photoUrl);
        }

        photoUrl = URL.createObjectURL(selectedFile);
        const nextPhoto = new Image();

        nextPhoto.addEventListener("load", () => {
            photo = nextPhoto;
            renderPhoto();
            if (placeholder) {
                placeholder.textContent = "Fotografía cargada correctamente.";
            }
        });

        nextPhoto.src = photoUrl;
    });

    downloadBtn?.addEventListener("click", () => {
        if (!canvas || !photo) {
            alert("Por favor, selecciona e introduce una fotografía antes de descargar.");
            return;
        }
        const dataUrl = canvas.toDataURL("image/png");
        const link = document.createElement("a");
        link.download = "fotografia_institucional_tescha.png";
        link.href = dataUrl;
        link.click();
    });

    paintEmptyCanvas();
</script>