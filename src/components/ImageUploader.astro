---
// src/components/ImageUploader.astro
---

<div class="rounded-xl border border-slate-200 bg-slate-50 p-5 mb-6">
    <!-- Título de sección unificado -->
    <h2 class="text-xl font-semibold text-tescha-wine">
        Cargar fotografía
    </h2>
    <p class="mt-1 text-sm text-slate-500">
        Selecciona una imagen JPG, PNG o WebP.
    </p>

    <div class="mt-4">
        <label
            for="file-input"
            class="flex flex-col items-center justify-center border-2 border-dashed border-slate-300 bg-white rounded-lg p-6 text-center cursor-pointer hover:bg-slate-50 transition-colors group"
        >
            <svg class="size-8 text-slate-400 group-hover:text-tescha-wine transition-colors mb-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
            </svg>
            <span class="text-sm font-medium text-slate-700">Haz clic para seleccionar una imagen</span>
            <span class="text-xs text-slate-400 mt-1">Tamaño máximo: 10 MB</span>
            <input id="file-input" type="file" accept="image/*" class="hidden" />
        </label>
    </div>
</div>

<script>
    const fileInput = document.querySelector<HTMLInputElement>("#file-input");

    fileInput?.addEventListener("change", (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) {
            const event = new CustomEvent("photo:selected", { detail: file });
            document.dispatchEvent(event);
        }
    });
</script>